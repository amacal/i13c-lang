asm exit(code@rdi: u8) noreturn clobbers rcx, r11, rax {
    mov rax, 0x3c;
    syscall;
}

asm print_asm(value@rax: u32) clobbers rcx, r11, rax {
    bswap rax;
    mov rcx, 0x3030303030303030;
    add rax, rcx;
    mov [rsp - 0x10], rax;

    mov r11, 0x0a;
    mov [rsp - 0x08], r11;

    mov rdi, 0x01;
    lea rsi, [rsp - 0x10];
    mov rdx, 0x09;
    mov rax, 0x01;
    syscall;
}

fn print(value: u32) {
  print_asm(value);
}

fn main() noreturn {
  print(0x01020304);
  exit(0x00);
}
