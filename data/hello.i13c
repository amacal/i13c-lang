asm exit(code@rdi: u8[0x00..0x0f]) noreturn clobbers rcx, r11, rax {
    mov rax, 0x3c;
    syscall;
}

asm close(fd@rdi: u8[0x00..0xff]) clobbers rcx, r11, rax {
    mov rax, 0x03;
    syscall;
}

fn close_std(fd: u8[0x00..0x02]) {
  val x: u8 = 0x00;
  val y: u8 = fd;

  close(fd);
}

fn foo(fd1: u8[0x00..0x02], fd2: u8[0x00..0x02], code: u8[0x00..0x0f]) noreturn {
  close_std(fd1);
  close_std(fd2);
  exit(code);
}

fn main() noreturn {
  foo(0x00, 0x01, 0x02);
}
